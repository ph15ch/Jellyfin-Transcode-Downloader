<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Jellyfin 10.11.x is built on .NET 9; its SDK packages target net9.0. -->
    <TargetFramework>net9.0</TargetFramework>
    <AssemblyName>Jellyfin.Plugin.TranscodeDownloader</AssemblyName>
    <RootNamespace>Jellyfin.Plugin.TranscodeDownloader</RootNamespace>
    <Version>0.0.0</Version>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
  </PropertyGroup>

  <!-- ASP.NET Core types (ControllerBase, [ApiController], etc.) for the controller. -->
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <!-- Jellyfin SDK references — not bundled into the output (provided at runtime by Jellyfin itself).
         Aligned to 10.11.8, the targeted ABI floor. -->
    <PackageReference Include="Jellyfin.Model" Version="10.11.8" PrivateAssets="All" />
    <PackageReference Include="Jellyfin.Common" Version="10.11.8" PrivateAssets="All" />
    <PackageReference Include="Jellyfin.Controller" Version="10.11.8" PrivateAssets="All" />
    <!-- Newtonsoft JObject is the parameter type of the File Transformation plugin's
         RegisterTransformation(JObject) entry point. Jellyfin ships Newtonsoft at
         runtime, so this is reference-only (PrivateAssets=All). -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.1" PrivateAssets="All" />
  </ItemGroup>

  <!-- The client script is embedded and served by TranscodeDownloaderController; it is
       never written to disk, so nothing is copied to the build output's web/ folder. -->
  <ItemGroup>
    <EmbeddedResource Include="..\web\plugin.js">
      <LogicalName>Jellyfin.Plugin.TranscodeDownloader.web.plugin.js</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

</Project>
